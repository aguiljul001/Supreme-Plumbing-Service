<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 750" width="100%" height="100%">
  <defs>
    <!-- Background and Ambient Glow Gradients -->
    <radialGradient id="interiorGlow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#10b981" stop-opacity="0.18" />
      <stop offset="100%" stop-color="#030712" stop-opacity="0" />
    </radialGradient>
    <linearGradient id="skyGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#070c1d" />
      <stop offset="60%" stop-color="#030712" />
      <stop offset="100%" stop-color="#0e1726" />
    </linearGradient>
    <linearGradient id="groundGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#050a14" />
      <stop offset="10%" stop-color="#010306" />
      <stop offset="100%" stop-color="#050a14" />
    </linearGradient>
    
    <!-- Van Body Gradients -->
    <linearGradient id="vanBody" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#f8fafc" />
      <stop offset="70%" stop-color="#f1f5f9" />
      <stop offset="100%" stop-color="#cbd5e1" />
    </linearGradient>
    
    <!-- Red Milwaukee Box gradients -->
    <linearGradient id="milwaukeeRed" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#ef4444" />
      <stop offset="100%" stop-color="#991b1b" />
    </linearGradient>
    <linearGradient id="milwaukeeDarkRed" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#b91c1c" />
      <stop offset="100%" stop-color="#7f1d1d" />
    </linearGradient>
    <linearGradient id="metalHanger" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#94a3b8" />
      <stop offset="100%" stop-color="#475569" />
    </linearGradient>
  </defs>

  <!-- Sky Background -->
  <rect width="1000" height="500" fill="url(#skyGrad)" />
  
  <!-- Ground (Asphalt) -->
  <rect y="500" width="1000" height="250" fill="url(#groundGrad)" />
  
  <!-- Green Tech Ambient Glow behind the van interior -->
  <circle cx="500" cy="375" r="320" fill="url(#interiorGlow)" />

  <!-- Ground Grid Markings -->
  <g opacity="0.25" stroke="#10b981" stroke-width="1.5">
    <line x1="200" y1="500" x2="-100" y2="750" />
    <line x1="400" y1="500" x2="150" y2="750" />
    <line x1="600" y1="500" x2="450" y2="750" />
    <line x1="800" y1="500" x2="750" y2="750" />
  </g>

  <!-- Heavy shadow under the van -->
  <ellipse cx="510" cy="535" rx="380" ry="25" fill="black" opacity="0.75" filter="blur(10px)" />
  <ellipse cx="510" cy="540" rx="340" ry="12" fill="#020617" opacity="0.9" />

  <!-- ==================== THE SPRINTER PLUMBING VAN (CLOSED SECTIONS + OPEN SLIDER) ==================== -->
  <g id="plumbingVan">
    <!-- Main Van Silhouette Body -->
    <path d="M 120,490 
             L 120,240 
             C 120,225 130,210 148,205 
             L 660,195 
             C 690,195 720,200 740,215 
             L 820,285
             C 845,310 855,340 855,370 
             L 865,420
             C 865,445 860,470 850,490
             L 830,500
             L 140,500 Z" 
          fill="url(#vanBody)" 
          stroke="#475569" 
          stroke-width="1.5" />

    <!-- Black Lower Trim / Rocker Panel Accent -->
    <path d="M 120,470 L 220,470 A 60,60 0 0,1 340,470 L 670,470 A 60,60 0 0,1 790,470 L 845,470 L 850,490 L 140,500 Z" fill="#0f172a" />

    <!-- Wheels (Premium Chrome Alloys) -->
    <g transform="translate(280, 475)">
      <circle cx="0" cy="0" r="50" fill="#1e293b" stroke="#0f172a" stroke-width="4" />
      <circle cx="0" cy="0" r="32" fill="#94a3b8" />
      <circle cx="0" cy="0" r="24" fill="#475569" />
      <circle cx="0" cy="0" r="14" fill="#cbd5e1" stroke="#334155" stroke-width="2" />
      <path d="M 0,-32 L 0,32 M -32,0 L 32,0" stroke="#cbd5e1" stroke-width="3" />
      <circle cx="0" cy="0" r="6" fill="#f1f5f9" />
    </g>
    <g transform="translate(730, 475)">
      <circle cx="0" cy="0" r="50" fill="#1e293b" stroke="#0f172a" stroke-width="4" />
      <circle cx="0" cy="0" r="32" fill="#94a3b8" />
      <circle cx="0" cy="0" r="24" fill="#475569" />
      <circle cx="0" cy="0" r="14" fill="#cbd5e1" stroke="#334155" stroke-width="2" />
      <path d="M 0,-32 L 0,32 M -32,0 L 32,0" stroke="#cbd5e1" stroke-width="3" />
      <circle cx="0" cy="0" r="6" fill="#f1f5f9" />
    </g>

    <!-- Windshield & Front Windows -->
    <path d="M 735,215 L 805,280 L 815,320 L 730,320 Z" fill="#0f172a" stroke="#1e293b" stroke-width="3" />
    <path d="M 640,240 L 710,240 L 715,310 L 610,310 C 610,270 620,245 640,240 Z" fill="#020617" stroke="#334155" stroke-width="2" />

    <!-- ==================== THE OPEN SLIDING DOOR PORTAL ==================== -->
    <!-- Dark deep interior cutout -->
    <path d="M 360,210 L 590,210 L 590,470 L 360,470 Z" fill="#05070e" stroke="#0f172a" stroke-width="4" />

    <!-- Door Sliding Tracks and Seals -->
    <rect x="357" y="206" width="236" height="6" fill="#1e293b" />
    <rect x="357" y="466" width="236" height="6" fill="#1e293b" />

    <!-- INTERIOR CONTENT: THE HIGHLY ORGANIZED MILWAUKEE RACKS -->
    <g transform="translate(370, 215)" id="vanInteriorRack">
      <!-- Dark shelving backing structure matrix -->
      <rect x="5" y="5" width="205" height="245" fill="#0b0f19" rx="5" />
      <line x1="5" y1="90" x2="210" y2="90" stroke="#1e293b" stroke-width="3" />
      <line x1="5" y1="170" x2="210" y2="170" stroke="#1e293b" stroke-width="3" />

      <!-- SHELF 3 (TOP): Small parts organizers, fittings, copper joiners -->
      <g transform="translate(10, 10)">
        <text x="5" y="12" font-family="monospace" font-size="9" fill="#10b981" font-weight="900" letter-spacing="0.5px">PARTS ORGANIZERS</text>
        
        <!-- Two Milwaukee-style sorting cases side-by-side -->
        <!-- Case 1 -->
        <rect x="5" y="18" width="85" height="55" rx="5" fill="url(#milwaukeeRed)" stroke="#7f1d1d" stroke-width="2" />
        <rect x="15" y="24" width="65" height="40" rx="3" fill="#020617" opacity="0.6" />
        <text x="20" y="38" font-family="system-ui" font-size="12" fill="#ffffff" font-weight="900">MILW</text>
        <rect x="40" y="52" width="15" height="6" fill="#1e293b" rx="1" /> <!-- lock clip -->
        
        <!-- Case 2 -->
        <rect x="100" y="18" width="85" height="55" rx="5" fill="url(#milwaukeeRed)" stroke="#7f1d1d" stroke-width="2" />
        <rect x="110" y="24" width="65" height="40" rx="3" fill="#020617" opacity="0.6" />
        <text x="115" y="38" font-family="system-ui" font-size="12" fill="#ffffff" font-weight="900">PACK</text>
        <rect x="135" y="52" width="15" height="6" fill="#1e293b" rx="1" />
      </g>

      <!-- SHELF 2 (MIDDLE): Heavier Drawer System (Crimson Milwaukee Packout Drawers) -->
      <g transform="translate(10, 95)">
        <text x="5" y="12" font-family="monospace" font-size="9" fill="#10b981" font-weight="900" letter-spacing="0.5px">DRAWER STACKS (MILWAUKEE)</text>
        
        <!-- Large double drawer unit -->
        <rect x="5" y="18" width="180" height="50" rx="6" fill="url(#milwaukeeDarkRed)" stroke="#450a0a" stroke-width="3" />
        
        <!-- Drawer 1 -->
        <rect x="12" y="24" width="166" height="16" rx="2" fill="#020617" />
        <rect x="80" y="29" width="30" height="6" rx="3" fill="#ef4444" /> <!-- red handle -->
        
        <!-- Drawer 2 -->
        <rect x="12" y="44" width="166" height="16" rx="2" fill="#020617" />
        <rect x="80" y="49" width="30" height="6" rx="3" fill="#ef4444" /> <!-- red handle -->
      </g>

      <!-- SHELF 1 (BOTTOM): Heavy power tools, roll bags, vacuum lines -->
      <g transform="translate(10, 175)">
        <text x="5" y="12" font-family="monospace" font-size="9" fill="#10b981" font-weight="900" letter-spacing="0.5px">HEAVY-DUTY EQUIPMENT</text>
        
        <!-- Giant Rolling Toolchest Base -->
        <rect x="5" y="18" width="180" height="50" rx="6" fill="url(#milwaukeeRed)" />
        <rect x="12" y="24" width="166" height="38" rx="2" fill="#0f172a" stroke="#ef4444" stroke-width="1" />
        
        <!-- Handlebar and Aluminum side bars detail -->
        <rect x="18" y="28" width="8" height="30" fill="url(#metalHanger)" />
        <rect x="164" y="28" width="8" height="30" fill="url(#metalHanger)" />
        <rect x="40" y="36" width="100" height="16" fill="#1e293b" rx="2" />
        <text x="50" y="48" font-family="sans-serif" font-weight="900" font-size="10" fill="#cbd5e1" letter-spacing="1.5px">SUPREME</text>
      </g>
    </g>

    <!-- PEX Hangers, pipelines, and coil spools hanging on the left open area -->
    <g transform="translate(372, 440)">
      <!-- Blue PEX line roll -->
      <circle cx="0" cy="0" r="14" fill="none" stroke="#2563eb" stroke-width="6" opacity="0.8" />
      <circle cx="5" cy="5" r="14" fill="none" stroke="#2563eb" stroke-width="4" opacity="0.6" />
      <!-- Red PEX line roll -->
      <circle cx="22" cy="0" r="14" fill="none" stroke="#ef4444" stroke-width="6" opacity="0.8" />
      <circle cx="27" cy="5" r="14" fill="none" stroke="#ef4444" stroke-width="4" opacity="0.6" />
    </g>

    <!-- Side sliding door, rolled back (extending past the frame to the left) -->
    <!-- The door shows the glowing emblem & WA license from the closed state but tilted/offset -->
    <g transform="translate(141, 230) scale(0.9)" opacity="0.75" id="slidDoorBack">
      <rect width="240" height="230" rx="15" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="3" />
      
      <!-- Partial supreme logo showing on the rolled door -->
      <g transform="translate(30, 40) scale(0.7)">
        <rect width="250" height="130" rx="15" fill="#1e293b" />
        <text x="20" y="45" font-family="sans-serif" font-weight="900" font-size="20" fill="#ffffff">SUPREME</text>
        <text x="20" y="75" font-family="sans-serif" font-weight="900" font-size="20" fill="#ef4444">PLUMBING</text>
        <text x="20" y="105" font-family="sans-serif" font-weight="700" font-size="12" fill="#cbd5e1">SERVICE</text>
      </g>
    </g>

    <!-- Additional text printed directly on the doors (compliance/licensing details) -->
    <text x="160" y="460" font-family="system-ui, -apple-system, sans-serif" font-weight="700" font-size="10" fill="#475569" letter-spacing="0.5px">
      VANCOUVER, WA • SOUTHWEST WA METRO
    </text>
    <text x="445" y="460" font-family="system-ui, -apple-system, sans-serif" font-weight="700" font-size="10" fill="#10b981" letter-spacing="0.5px">
      LIC: SUPREPS747K2
    </text>
  </g>

</svg>
