<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 750" width="100%" height="100%">
  <defs>
    <!-- Background and Ambient Glow Gradients -->
    <radialGradient id="ambientGlow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#ef4444" stop-opacity="0.15" />
      <stop offset="100%" stop-color="#030712" stop-opacity="0" />
    </radialGradient>
    <linearGradient id="skyGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#0b1329" />
      <stop offset="60%" stop-color="#030712" />
      <stop offset="100%" stop-color="#0f172a" />
    </linearGradient>
    <linearGradient id="groundGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#050b18" />
      <stop offset="10%" stop-color="#02040a" />
      <stop offset="100%" stop-color="#070d1e" />
    </linearGradient>
    
    <!-- Van Body Gradients -->
    <linearGradient id="vanBody" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#f8fafc" />
      <stop offset="70%" stop-color="#f1f5f9" />
      <stop offset="100%" stop-color="#cbd5e1" />
    </linearGradient>
    <linearGradient id="vanShadow" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#020617" stop-opacity="0.8" />
      <stop offset="100%" stop-color="#020617" stop-opacity="0" />
    </linearGradient>
    <linearGradient id="bumperGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#334155" />
      <stop offset="100%" stop-color="#1e293b" />
    </linearGradient>
    
    <!-- Logo & Signage Gradients -->
    <linearGradient id="logoBorder" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#ef4444" />
      <stop offset="100%" stop-color="#b91c1c" />
    </linearGradient>
    <linearGradient id="logoBg" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#0f172a" />
      <stop offset="100%" stop-color="#1e293b" />
    </linearGradient>
    <linearGradient id="waterDrop" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#38bdf8" />
      <stop offset="100%" stop-color="#0284c7" />
    </linearGradient>
  </defs>

  <!-- Sky Background -->
  <rect width="1000" height="500" fill="url(#skyGrad)" />
  
  <!-- Ground (Asphalt) -->
  <rect y="500" width="1000" height="250" fill="url(#groundGrad)" />
  
  <!-- Red Ambient Glow behind the van -->
  <circle cx="500" cy="375" r="350" fill="url(#ambientGlow)" />

  <!-- Ground Grid Markings (Perspective parking lines) -->
  <g opacity="0.3" stroke="#ef4444" stroke-width="2">
    <line x1="200" y1="500" x2="-100" y2="750" />
    <line x1="400" y1="500" x2="150" y2="750" />
    <line x1="600" y1="500" x2="450" y2="750" />
    <line x1="800" y1="500" x2="750" y2="750" />
    <line x1="1000" y1="500" x2="1050" y2="750" />
  </g>

  <!-- Heavy shadow under the van -->
  <ellipse cx="510" cy="535" rx="380" ry="25" fill="black" opacity="0.75" filter="blur(10px)" />
  <ellipse cx="510" cy="540" rx="340" ry="12" fill="#020617" opacity="0.9" />

  <!-- ==================== THE SPRINTER PLUMBING VAN ==================== -->
  <g id="plumbingVan">
    <!-- Back Wheel & Front Wheel Shadows -->
    <ellipse cx="280" cy="530" rx="48" ry="12" fill="black" opacity="0.6" />
    <ellipse cx="730" cy="530" rx="48" ry="12" fill="black" opacity="0.6" />

    <!-- Main Van Silhouette Body -->
    <path d="M 120,490 
             L 120,240 
             C 120,225 130,210 148,205 
             L 660,195 
             C 690,195 720,200 740,215 
             L 820,285
             C 845,310 855,340 855,370 
             L 865,420
             C 865,445 860,470 850,490
             L 830,500
             L 140,500 Z" 
          fill="url(#vanBody)" 
          stroke="#475569" 
          stroke-width="1.5" />

    <!-- Black Lower Trim / Rocker Panel Accent -->
    <path d="M 120,470 L 220,470 A 60,60 0 0,1 340,470 L 670,470 A 60,60 0 0,1 790,470 L 845,470 L 850,490 L 140,500 Z" fill="#0f172a" />
    
    <!-- Front Wheel Well Trim -->
    <path d="M 670,470 A 60,60 0 0,1 790,470" fill="none" stroke="#475569" stroke-width="6" />
    <!-- Rear Wheel Well Trim -->
    <path d="M 220,470 A 60,60 0 0,1 340,470" fill="none" stroke="#475569" stroke-width="6" />

    <!-- Front Bumper -->
    <path d="M 830,460 C 855,460 868,475 868,495 L 850,515 L 820,515 Z" fill="url(#bumperGrad)" stroke="#0f172a" />
    <!-- Rear Bumper -->
    <path d="M 115,465 C 110,465 110,495 125,502 L 145,500 Z" fill="url(#bumperGrad)" />

    <!-- Wheels (Premium Chrome Alloys) -->
    <!-- Rear Wheel -->
    <g transform="translate(280, 475)">
      <circle cx="0" cy="0" r="50" fill="#1e293b" stroke="#0f172a" stroke-width="4" />
      <circle cx="0" cy="0" r="32" fill="#94a3b8" />
      <circle cx="0" cy="0" r="24" fill="#475569" />
      <circle cx="0" cy="0" r="14" fill="#cbd5e1" stroke="#334155" stroke-width="2" />
      <path d="M 0,-32 L 0,32 M -32,0 L 32,0" stroke="#cbd5e1" stroke-width="3" />
      <circle cx="0" cy="0" r="6" fill="#f1f5f9" />
    </g>
    <!-- Front Wheel -->
    <g transform="translate(730, 475)">
      <circle cx="0" cy="0" r="50" fill="#1e293b" stroke="#0f172a" stroke-width="4" />
      <circle cx="0" cy="0" r="32" fill="#94a3b8" />
      <circle cx="0" cy="0" r="24" fill="#475569" />
      <circle cx="0" cy="0" r="14" fill="#cbd5e1" stroke="#334155" stroke-width="2" />
      <path d="M 0,-32 L 0,32 M -32,0 L 32,0" stroke="#cbd5e1" stroke-width="3" />
      <circle cx="0" cy="0" r="6" fill="#f1f5f9" />
    </g>

    <!-- Windshield -->
    <path d="M 735,215 L 805,280 L 815,320 L 730,320 Z" fill="#0f172a" stroke="#1e293b" stroke-width="3" />
    <path d="M 742,225 L 795,275 L 800,310 L 740,310 Z" fill="#1e293b" opacity="0.6" />

    <!-- Front Cabin Side Window -->
    <path d="M 640,240 L 710,240 L 715,310 L 610,310 C 610,270 620,245 640,240 Z" fill="#020617" stroke="#334155" stroke-width="2" />
    <!-- Passenger window division bar -->
    <line x1="680" y1="240" x2="685" y2="310" stroke="#334155" stroke-width="3" />

    <!-- Door Handles -->
    <!-- Drivers Door Handle -->
    <rect x="600" y="335" width="28" height="10" rx="3" fill="#1e293b" stroke="#475569" />
    <!-- Sliding Side Door Handle -->
    <rect x="420" y="335" width="28" height="10" rx="3" fill="#1e293b" stroke="#475569" />

    <!-- Body Panel Lines (Doors, Panels, Sliders) -->
    <g stroke="#94a3b8" stroke-width="1.5" opacity="0.8">
      <!-- Front Passenger Door Outline -->
      <path d="M 590,225 L 590,470 M 590,225 L 725,225 L 730,350 L 720,470" fill="none" />
      <!-- Sliding Door Panel Outline -->
      <path d="M 360,210 L 360,470 M 580,210 L 580,470 M 360,210 L 580,210" fill="none" />
      <!-- Horizontal body crease lines -->
      <line x1="120" y1="280" x2="590" y2="280" />
      <line x1="120" y1="365" x2="590" y2="365" />
      <!-- Keylock details / fuel cap -->
      <circle cx="160" cy="430" r="10" fill="none" />
    </g>

    <!-- Side View Mirror -->
    <path d="M 718,285 L 705,290 L 701,310 L 718,305 Z" fill="#020617" />
    <rect x="715" y="270" width="12" height="38" rx="4" fill="#1e293b" />

    <!-- Roof Utility Racks / Ladders (High Grade Professional Accents) -->
    <rect x="200" y="180" width="400" height="15" fill="none" stroke="#64748b" stroke-width="4" />
    <path d="M 180,195 L 200,180" stroke="#64748b" stroke-width="4" />
    <path d="M 620,195 L 600,180" stroke="#64748b" stroke-width="4" />
    <!-- Pipes strapped to the rack -->
    <rect x="150" y="172" width="480" height="9" rx="3" fill="#cbd5e1" stroke="#94a3b8" stroke-width="1" />
    <circle cx="630" cy="176.5" r="4.5" fill="#facc15" /> <!-- yellow pipe cap -->

    <!-- ==================== PREMIUM LITERAL GRAPHIC SIGNAGE ==================== -->
    <g transform="translate(160, 275)" id="vanBrandingPanel">
      <!-- Sign Border & Backdrop Plate (Sleek Glassmorphic Sheet) -->
      <rect width="360" height="170" rx="20" fill="url(#logoBg)" stroke="url(#logoBorder)" stroke-width="3" />
      <rect x="5" y="5" width="350" height="160" rx="15" fill="none" stroke="#ffffff" stroke-opacity="0.1" stroke-width="2" />
      
      <!-- Blue Waves Graphic Backdrop in sign -->
      <path d="M 10,120 Q 90,80 180,110 T 350,115 L 350,165 L 10,165 Z" fill="#0ea5e9" fill-opacity="0.1" />
      <path d="M 10,135 Q 110,110 200,135 T 350,125 L 350,165 L 10,165 Z" fill="#2563eb" fill-opacity="0.15" />

      <!-- Glowing Red Plumbing Wrench and Water Droplet Branding -->
      <g transform="translate(30, 85) scale(1.6)" id="glowingEmblem">
        <!-- Droplet -->
        <path d="M 0,0 C -8,10 -10,18 0,18 C 10,18 8,10 0,0 Z" fill="url(#waterDrop)" />
        <ellipse cx="-2" cy="14" rx="3" ry="5" fill="#ffffff" opacity="0.4" transform="rotate(-30)" />
        
        <!-- Large Wrench Intersecting -->
        <g transform="rotate(-35, 10, 5) translate(-10, -5)">
          <rect x="-4" y="-30" width="8" height="40" rx="3" fill="#ef4444" stroke="#991b1b" stroke-width="1" />
          <!-- Wrench jaws -->
          <path d="M -10,-28 L 10,-28 L 10,-38 L -10,-38 Z" fill="#ef4444" stroke="#991b1b" stroke-width="1" />
          <rect x="-6" y="-35" width="12" height="4" fill="#cbd5e1" />
          <!-- Adjusting nut -->
          <circle cx="0" cy="-12" r="6" fill="#94a3b8" />
        </g>
      </g>

      <!-- Bold Metallic Headline Text -->
      <text x="140" y="42" font-family="system-ui, -apple-system, sans-serif" font-weight="950" font-size="28" fill="#ffffff" letter-spacing="-1px">
        SUPREME
      </text>
      <text x="140" y="74" font-family="system-ui, -apple-system, sans-serif" font-weight="950" font-size="28" fill="#ef4444" letter-spacing="-1px">
        PLUMBING
      </text>
      <!-- Accent Line -->
      <line x1="140" y1="84" x2="330" y2="84" stroke="#ef4444" stroke-width="3" />
      
      <!-- Subtitle -->
      <text x="140" y="104" font-family="system-ui, -apple-system, sans-serif" font-weight="700" font-size="16" fill="#cbd5e1" letter-spacing="1px">
        SERVICE
      </text>

      <!-- Highly Legible Phone Number Callout -->
      <text x="140" y="145" font-family="system-ui, -apple-system, sans-serif" font-weight="900" font-size="28" fill="#ffffff" letter-spacing="1px">
        564-888-3159
      </text>
    </g>

    <!-- Additional text printed directly on the doors (compliance/licensing details) -->
    <!-- Vancouver Area Text -->
    <text x="160" y="460" font-family="system-ui, -apple-system, sans-serif" font-weight="700" font-size="10" fill="#475569" letter-spacing="0.5px">
      VANCOUVER, WA • SOUTHWEST WA METRO
    </text>
    <!-- WA Contractor License SUPREPS747K2 -->
    <text x="445" y="460" font-family="system-ui, -apple-system, sans-serif" font-weight="700" font-size="10" fill="#ef4444" letter-spacing="0.5px">
      LIC: SUPREPS747K2
    </text>
  </g>

</svg>
